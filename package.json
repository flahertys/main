{
  "name": "tradehax",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:cpanel": "node ./server.js",
    "lint": "eslint . --ignore-pattern next-env.d.ts",
    "lint:fix": "eslint . --fix --ignore-pattern next-env.d.ts",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "format": "prettier --write .",
    "clean": "rimraf .next out node_modules/.cache",
    "clean:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/cleanup.ps1",
    "reinstall": "rimraf node_modules package-lock.json && npm install",
    "generate:all": "echo 'Image generation skipped (tools not configured)'",
    "hooks:install": "node ./scripts/install-hooks.js",
    "deploy:build": "npm run clean && npm run build",
    "check:vercel": "node ./scripts/check-deploy-config.js --vercel",
    "check:links": "node ./scripts/validate-internal-links.js",
    "check:links:report": "node ./scripts/validate-internal-links.js --report=.artifacts/link-audit-report.json --sarif=.artifacts/link-audit.sarif",
    "check:links:strict": "node ./scripts/validate-internal-links.js --strict",
    "check:links:strict:report": "node ./scripts/validate-internal-links.js --strict --report=.artifacts/link-audit-report.json --sarif=.artifacts/link-audit.sarif",
    "check:links:changed": "node ./scripts/validate-internal-links.js --changed --report=.artifacts/link-audit-report.json --sarif=.artifacts/link-audit.sarif",
    "check:dns": "node ./scripts/check-deploy-config.js --dns",
    "pipeline:quality": "npm run lint && npm run type-check",
    "pipeline:local": "npm run pipeline:quality && npm run check:links && npm run build",
    "pipeline:alpha": "npm run alpha:preflight && npm run pipeline:quality",
    "pipeline:deploy-checks": "node ./scripts/check-deploy-config.js",
    "pipeline:ci": "node ./scripts/run-pipeline-ci.js",
    "deploy:one-click": "node ./scripts/one-button-deploy.js --prod",
    "deploy:one-click:strict-dns": "node ./scripts/one-button-deploy.js --prod --strict-dns",
    "deploy:one-click:preview": "node ./scripts/one-button-deploy.js --preview",
    "deploy:one-click:preview:strict-dns": "node ./scripts/one-button-deploy.js --preview --strict-dns",
    "deploy:namecheap:check": "node ./scripts/check-namecheap-deploy-config.js",
    "llm:prepare-dataset": "node ./scripts/prepare-custom-llm-dataset.js",
    "llm:validate-dataset": "node ./scripts/validate-custom-llm-dataset.js",
    "llm:check": "node ./scripts/check-llm-config.js",
    "llm:prepare-and-validate": "npm run llm:prepare-dataset && npm run llm:validate-dataset",
    "llm:finetune:deps": "python -m pip install -r ./scripts/fine-tune-requirements.txt",
    "fine-tune": "node scripts/run-finetune-workflow.js",
    "llm:finetune": "python ./scripts/fine-tune-mistral-lora.py",
    "llm:finetune:push": "python ./scripts/fine-tune-mistral-lora.py --push-to-hub",
    "llm:finetune:workflow": "node ./scripts/run-finetune-workflow.js",
    "llm:finetune:workflow:push": "node ./scripts/run-finetune-workflow.js --push",
    "tradebot:prepare-training": "node ./scripts/prepare-tradebot-training.js",
    "tradebot:validate-training": "node ./scripts/validate-tradebot-training.js",
    "tradebot:build-training": "npm run tradebot:prepare-training && npm run tradebot:validate-training",
    "tradebot:generate-eval-suite": "node ./scripts/generate-tradebot-eval-suite.js",
    "tradebot:init-eval-responses": "node ./scripts/init-tradebot-eval-responses.js",
    "tradebot:score-eval": "node ./scripts/score-tradebot-eval.js",
    "tradebot:evaluate": "npm run tradebot:generate-eval-suite && npm run tradebot:init-eval-responses && npm run tradebot:score-eval",
    "hf:automation": "node ./scripts/complete-automation.js",
    "hf:validate": "node ./scripts/validate-deployment.js",
    "hf:setup-vercel": "node ./scripts/setup-vercel-deployment.js",
    "hf:test-inference": "node ./scripts/test-inference.js",
    "rag:ingest:intelligence": "node ./scripts/ingest-rag-intelligence.js",
    "rag:ingest:intelligence:json": "node ./scripts/ingest-rag-intelligence.js --json",
    "hf:sync-assets": "node ./scripts/sync-hf-assets-safe.js",
    "hf:sync-assets:direct": "node ./scripts/sync-hf-assets.js",
    "ai:env:doctor": "node ./scripts/ai-env-doctor.js",
    "ai:env:doctor:strict": "node ./scripts/ai-env-doctor.js --strict",
    "ai:live:readiness": "node ./scripts/ai-env-doctor.js",
    "ai:live:readiness:strict": "node ./scripts/ai-env-doctor.js --strict",
    "ai:live:readiness:json": "node ./scripts/ai-env-doctor.js --json",
    "hivemind:doctor": "node ./scripts/hivemind-readiness.js",
    "hivemind:doctor:strict": "node ./scripts/hivemind-readiness.js --strict",
    "hivemind:benchmark": "node ./scripts/hivemind-benchmark-trend.js",
    "hivemind:benchmark:strict": "node ./scripts/hivemind-benchmark-trend.js --strict",
    "hivemind:quality:strict": "npm run hivemind:doctor:strict && npm run hivemind:benchmark:strict",
    "alpha:preflight": "node ./scripts/alpha-preflight.js",
    "hf:pipeline": "npm run hf:validate && npm run pipeline:quality",
    "hf:pipeline:strict": "npm run hf:pipeline && npm run pipeline:local",
    "social:setup": "node ./scripts/setup-social-apis.js",
    "social:check": "node ./scripts/check-social-api-config.js",
    "auth:hash-password": "node ./scripts/generate-admin-password-hash.js",
    "auth:check": "node ./scripts/check-admin-login-config.js",
    "discord:register-commands": "node ./scripts/discord/register-commands.mjs",
    "discord:publish-signals": "node ./scripts/discord/publish-signals.mjs",
    "trading:cadence:run": "node ./scripts/run-trading-signal-cadence.mjs",
    "repo:status": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/repo-status.ps1",
    "repo:sync-mirror": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-mirror-from-canonical.ps1",
    "ide:sync": "node ./scripts/ide-sync-pipeline.js",
    "ide:sync:full": "node ./scripts/ide-sync-pipeline.js --install --build --namecheap",
    "ide:sync:deploy-ready": "node ./scripts/ide-sync-pipeline.js --install --build --namecheap --strict-namecheap",
    "deploy:launch": "node ./scripts/launch-website-deploy.js",
    "deploy:launch:strict": "node ./scripts/launch-website-deploy.js",
    "deploy:launch:dry-run": "node ./scripts/launch-website-deploy.js --dry-run",
    "deploy:launch:no-watch": "node ./scripts/launch-website-deploy.js --no-watch",
    "dev:aggressive": "node ./scripts/aggressive-dev-loop.js",
    "dev:aggressive:quick": "node ./scripts/aggressive-dev-loop.js --quick",
    "dev:aggressive:continue": "node ./scripts/aggressive-dev-loop.js --continue-on-error",
    "dev:aggressive:deploy-ready": "node ./scripts/aggressive-dev-loop.js --deploy-dry-run",
    "dev:aggressive:strict": "node ./scripts/aggressive-dev-loop.js --strict --fail-fast",
    "dev:aggressive:quick:strict": "node ./scripts/aggressive-dev-loop.js --quick --strict --fail-fast",
    "dev:aggressive:verify": "node ./scripts/verify-aggressive-dev-report.js",
    "dev:aggressive:verify:elite": "node ./scripts/verify-aggressive-dev-report.js --min-score 95",
    "dev:aggressive:prove": "npm run dev:aggressive:quick && npm run dev:aggressive:verify",
    "dev:aggressive:prove:elite": "npm run dev:aggressive:quick && npm run dev:aggressive:verify:elite",
    "dev:aggressive:prove:strict": "npm run dev:aggressive:quick:strict && npm run dev:aggressive:verify",
    "launch:readiness": "npm run check:links && npm run pipeline:quality && npm run check:vercel",
    "launch:readiness:strict": "npm run ide:sync:deploy-ready && npm run ai:env:doctor:strict && npm run social:check",
    "launch:professional": "npm run launch:readiness:strict && npm run deploy:launch",
    "perf:convert-images": "bash scripts/convert-images-to-webp.sh",
    "perf:analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.113",
    "@emailjs/browser": "^4.4.1",
    "@huggingface/inference": "^4.13.13",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@sentry/nextjs": "^10.42.0",
    "@upstash/vector": "^1.2.2",
    "@vercel/analytics": "^1.6.1",
    "ai": "^6.0.111",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.479.0",
    "next": "15.5.12",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "onnxruntime-web": "^1.24.1",
    "phaser": "^3.90.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.1",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.182.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^15.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.182.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.1.0",
    "eslint-config-next": "15.1.6",
    "jest": "^29.7.0",
    "postcss": "^8",
    "rimraf": "^5.0.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.12",
    "typescript": "^5"
  }
}