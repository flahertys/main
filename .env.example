VERCEL_AUTOMATION_BYPASS_SECRET=otWDNt0dMxhdDDdkNEPwodop676ofPP1

# Optional deploy hook URLs for Social Wizard "deploy after sync"
# Configure one shared hook, or target-specific hooks.
TRADEHAX_VERCEL_DEPLOY_HOOK_URL=
TRADEHAX_VERCEL_DEPLOY_HOOK_URL_PRODUCTION=
TRADEHAX_VERCEL_DEPLOY_HOOK_URL_PREVIEW=

# ============================================
# Feature Flags
# ============================================
# Toggle features on/off
NEXT_PUBLIC_ENABLE_WEB3_AUTH=true
NEXT_PUBLIC_ENABLE_SOCIAL_AUTH=false
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# Rate Limiting & Security
# ============================================
# Enable rate limiting for API routes
ENABLE_RATE_LIMITING=true

# NOTE: CORS is automatically configured by Next.js for API routes
# For custom CORS configuration, see app/api/*/route.ts files

# ============================================
# Development Only
# ============================================
# These should only be used in development, not production

# Enable debug logging
# DEBUG=true

# Disable HTTPS requirement in development
# DISABLE_HTTPS=true
