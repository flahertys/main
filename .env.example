# TradeHax.net HF Fine-Tuning Env Example (add to Vercel)
HF_API_TOKEN=your_token_here # Keep secret!
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.1
TRADEHAX_MODEL_GENERAL=mistralai/Mistral-7B-Instruct-v0.1
TRADEHAX_MODEL_STOCK=mistralai/Mistral-7B-Instruct-v0.1
TRADEHAX_MODEL_CRYPTO=mistralai/Mistral-7B-Instruct-v0.1
TRADEHAX_MODEL_KALSHI=mistralai/Mistral-7B-Instruct-v0.1
TRADEHAX_MODEL_GENERAL_CANARY=
TRADEHAX_MODEL_STOCK_CANARY=
TRADEHAX_MODEL_CRYPTO_CANARY=
TRADEHAX_MODEL_KALSHI_CANARY=
TRADEHAX_CANARY_ROLLOUT_PERCENT=15
TRADEHAX_CANARY_MIN_REQUESTS=40
TRADEHAX_CANARY_MIN_CONFIDENCE_GAIN=3
TRADEHAX_CANARY_MAX_FALLBACK_RATE=18
TRADEHAX_CANARY_MAX_FALLBACK_DELTA=5
TRADEHAX_CANARY_HYSTERESIS=1.5
TRADEHAX_CANARY_COOLDOWN_MINUTES=30
TRADEHAX_CANARY_WINDOW_SIZE=240
TRADEHAX_CANARY_PROMOTION_STREAK=3
TRADEHAX_CANARY_ROLLBACK_STREAK=2
HF_IMAGE_MODEL_ID=stabilityai/stable-diffusion-2-1

# Generation tuning
LLM_TEMPERATURE=0.85
LLM_MAX_LENGTH=768
LLM_TOP_P=0.95
HF_IMAGE_STEPS=30
HF_IMAGE_GUIDANCE_SCALE=6.5
HF_IMAGE_NEGATIVE_PROMPT_DEFAULT=blurry, low quality, watermark, logo, text overlay, disfigured

# HF Fine-Tuning Defaults
HF_HUB_MODEL_ID=irishpride81mf/tradehax-mistral-finetuned
DATASET_PATH=tradehax-training-expanded.jsonl
TRAIN_EPOCHS=3
TRAIN_BATCH_SIZE=4
TRAIN_LR=2e-5
LORA_R=16
LORA_ALPHA=32
TRADEHAX_WEIGHT_KALSHI=6
TRADEHAX_MIN_KALSHI_SHARE=0.03

# Open Mode controls (set to false to make responses more conservative)
TRADEHAX_LLM_OPEN_MODE=false
TRADEHAX_IMAGE_OPEN_MODE=true

# Admin + ingestion controls
TRADEHAX_ADMIN_KEY=
TRADEHAX_SUPERUSER_CODE=
TRADEHAX_ALLOW_CLIENT_USER_ID_OVERRIDE=false
TRADEHAX_DATA_HASH_SALT=change-this-salt
TRADEHAX_BEHAVIOR_MAX_RECORDS=5000
TRADEHAX_DEFAULT_TRAINING_CONSENT=false
TRADEHAX_ALLOW_IMPLICIT_ANALYTICS_CONSENT=false
TRADEHAX_AI_TRAINING_STORAGE=memory
TRADEHAX_SUPABASE_AI_BENCHMARKS_TABLE=ai_training_benchmarks
TRADEHAX_SUPABASE_AI_PERSONALIZATION_TABLE=ai_trading_personalization_profiles
TRADEHAX_SUPABASE_AI_TRADE_OUTCOMES_TABLE=ai_trading_trade_outcomes

# ============================================
# Intelligence Phase 2
# ============================================
# Data provider mode: mock | vendor (auto-detect if blank)
INTELLIGENCE_DATA_PROVIDER=mock
TRADEHAX_INTELLIGENCE_PROVIDER=
INTELLIGENCE_VENDOR_NAME=unusualwhales

# Vendor API keys (set at least one to run vendor mode in live configuration)
UNUSUALWHALES_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
BLOOMBERG_API_KEY=
BPIPE_TOKEN=

# Discord alert routing webhooks
TRADEHAX_DISCORD_WEBHOOK=
TRADEHAX_DISCORD_WEBHOOK_FREE=
TRADEHAX_DISCORD_WEBHOOK_BASIC=
TRADEHAX_DISCORD_WEBHOOK_PRO=
TRADEHAX_DISCORD_WEBHOOK_ELITE=

# Optional Discord channel labels used in route metadata
TRADEHAX_DISCORD_CHANNEL_FREE=intel-community
TRADEHAX_DISCORD_CHANNEL_BASIC=intel-basic
TRADEHAX_DISCORD_CHANNEL_PRO=intel-pro
TRADEHAX_DISCORD_CHANNEL_ELITE=intel-elite

# Optional Discord thread routing (strategy + risk profile)
# Default thread id can be a Discord channel/thread id (example provided by user):
TRADEHAX_DISCORD_DEFAULT_THREAD_ID=1421509686443905094
TRADEHAX_DISCORD_THREAD_OPTIONS_FLOW=
TRADEHAX_DISCORD_THREAD_DARK_POOL=
TRADEHAX_DISCORD_THREAD_CRYPTO_FLOW=
TRADEHAX_DISCORD_THREAD_CATALYST_NEWS=
TRADEHAX_DISCORD_THREAD_URGENT=
TRADEHAX_DISCORD_THREAD_WATCH=
TRADEHAX_DISCORD_THREAD_INFO=
TRADEHAX_DISCORD_SERVER_ID=1421509686443905094

# Provider adapter tuning
TRADEHAX_INTELLIGENCE_CACHE_MS=15000
UNUSUALWHALES_BASE_URL=https://api.unusualwhales.com
UNUSUALWHALES_FLOW_ENDPOINT=
UNUSUALWHALES_DARK_POOL_ENDPOINT=
UNUSUALWHALES_NEWS_ENDPOINT=
POLYGON_BASE_URL=https://api.polygon.io
BLOOMBERG_PROXY_BASE_URL=
BLOOMBERG_FLOW_ENDPOINT=
BLOOMBERG_DARK_POOL_ENDPOINT=
BLOOMBERG_NEWS_ENDPOINT=
TRADEHAX_INTELLIGENCE_WS_ENABLED=false
TRADEHAX_INTELLIGENCE_WS_URL=
TRADEHAX_INTELLIGENCE_WS_PROTOCOL=
TRADEHAX_INTELLIGENCE_WS_RECONNECT_MS=4000

# Persistent watchlist/alert storage (Phase 3)
TRADEHAX_INTELLIGENCE_STORAGE=memory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TRADEHAX_SUPABASE_WATCHLIST_TABLE=tradehax_watchlist_items
TRADEHAX_SUPABASE_ALERTS_TABLE=tradehax_intelligence_alerts

# Vercel project metadata (safe to set in CI contexts)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=prj_LDmkGrAq06c1DJcH98BeN6GYhZpW

# Optional deploy hook URLs for Social Wizard "deploy after sync"
# Configure one shared hook, or target-specific hooks.
TRADEHAX_VERCEL_DEPLOY_HOOK_URL=
TRADEHAX_VERCEL_DEPLOY_HOOK_URL_PRODUCTION=
TRADEHAX_VERCEL_DEPLOY_HOOK_URL_PREVIEW=

# ============================================
# Feature Flags
# ============================================
# Toggle features on/off
NEXT_PUBLIC_ENABLE_WEB3_AUTH=true
NEXT_PUBLIC_ENABLE_SOCIAL_AUTH=false
NEXT_PUBLIC_ENABLE_PAYMENTS=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# Rate Limiting & Security
# ============================================
# Enable rate limiting for API routes
ENABLE_RATE_LIMITING=true

# NOTE: CORS is automatically configured by Next.js for API routes
# For custom CORS configuration, see app/api/*/route.ts files

# ============================================
# Development Only
# ============================================
# These should only be used in development, not production

# Enable debug logging
# DEBUG=true

# Disable HTTPS requirement in development
# DISABLE_HTTPS=true
