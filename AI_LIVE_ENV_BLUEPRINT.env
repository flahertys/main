TRADEHAX_RETRAIN_EXPORT_QUEUE_ENABLED=true
TRADEHAX_RETRAIN_EXPORT_QUEUE_STORAGE=memory
TRADEHAX_SUPABASE_AI_RETRAIN_QUEUE_TABLE=ai_retrain_export_queue

# ----------------------------
# ONE-PASS DEPLOY UNBLOCK CHECKLIST
# ----------------------------
# 1) Set REQUIRED Namecheap GitHub secrets above.
# 2) Keep Vercel runtime vars in Vercel Project Settings -> Environment Variables.
# 3) Run local strict gate: npm run ide:sync:deploy-ready
# 4) Trigger deploy: npm run deploy:launch
# 5) If skipped, verify only these are missing:
#    NAMECHEAP_VPS_HOST, NAMECHEAP_VPS_USER, NAMECHEAP_VPS_SSH_KEY
