# ----------------------------
TRADEHAX_DISCORD_WEBHOOK=
TRADEHAX_DISCORD_SIGNAL_WEBHOOK=
TRADEHAX_DISCORD_DEFAULT_THREAD_ID=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
