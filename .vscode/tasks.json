{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TradeHax: IDE Sync (Quick)",
      "type": "npm",
      "script": "ide:sync",
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^(error|warning|ERROR|WARNING).*$",
            "severity": "warning"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting.*sync.*$",
          "endsPattern": "^.*Sync.*complete.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "TradeHax: IDE Sync (Full)",
      "type": "npm",
      "script": "ide:sync:full",
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^(error|warning|ERROR|WARNING).*$",
            "severity": "warning"
          }
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "TradeHax: IDE Sync (Deploy Ready)",
      "type": "npm",
      "script": "ide:sync:deploy-ready",
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^(error|warning|ERROR|WARNING).*$",
            "severity": "warning"
          }
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "panel": "dedicated"
      }
    },
    {
      "label": "TradeHax: Lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": {
        "pattern": {
          "regexp": "^\\s*(.*?)\\s+(\\d+):(\\d+)\\s+(error|warning)\\s+(.*)$",
          "file": 1,
          "location": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "TradeHax: Type Check",
      "type": "npm",
      "script": "type-check",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "TradeHax: Build",
      "type": "npm",
      "script": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "TradeHax: Dev Server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*error.*)$",
          "severity": "error"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*ready.*$",
          "endsPattern": "^(?!.*ready.*).*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "TradeHax: Deploy to Namecheap",
      "type": "shell",
      "command": "bash",
      "args": [
        "scripts/deploy-to-namecheap.sh"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}
