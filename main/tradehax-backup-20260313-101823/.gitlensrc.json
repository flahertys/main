{
  "gitlens": {
    "remotes": [
      {
        "domain": "github.com",
        "type": "GitHub",
        "baseUrl": "https://github.com",
        "apiUrl": "https://api.github.com"
      }
    ],
    "hovers": {
      "currentLine": {
        "over": "line"
      }
    },
    "codeLens": {
      "enabled": true,
      "recentChange": {
        "enabled": true
      }
    }
  }
}