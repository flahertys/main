{
  "name": "tradehax-web-merge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node ./scripts/generate-build-meta.mjs",
    "build": "vite build",
    "start": "vite preview",
    "test:smoke": "node ./scripts/smoke-test.js",
    "verify:handshake": "node ./scripts/handshake-check.js",
    "release:check": "npm run test:smoke && npm run build",
    "audit:licenses": "node ./scripts/license-audit.mjs",
    "engine:backtest": "node ./scripts/engine-backtest.mjs",
    "engine:check": "npm run audit:licenses && npm run engine:backtest",
    "engine:report": "node ./scripts/engine-quality-report.mjs",
    "supabase:health": "node --env-file=.env.local ./scripts/supabase-health.mjs",
    "load:env": "node ./scripts/env-loader.mjs",
    "load:env:net": "npm run load:env -- --profile production --domain net",
    "load:env:tech": "npm run load:env -- --profile production --domain tech",
    "load:env:me": "npm run load:env -- --profile production --domain me",
    "load:env:local": "npm run load:env -- --profile local",
    "sync:env:vercel": "node ./scripts/vercel-env-sync.mjs",
    "sync:env:vercel:net": "node ./scripts/vercel-env-sync.mjs --target net --dry-run",
    "sync:env:vercel:tech": "node ./scripts/vercel-env-sync.mjs --target tech --dry-run",
    "sync:env:vercel:net:apply": "node ./scripts/vercel-env-sync.mjs --target net --apply --replace",
    "sync:env:vercel:tech:apply": "node ./scripts/vercel-env-sync.mjs --target tech --apply --replace",
    "verify:deploy-bundle": "node ./scripts/verify-deploy-bundle.mjs",
    "predeploy": "node ../scripts/predeploy-check.js",
    "deploy": "npm run predeploy && npx vercel --prod",
    "deploy:net": "npm run load:env:net && npm run deploy",
    "deploy:tech": "npm run load:env:tech && npm run deploy",
    "deploy:me": "npm run load:env:me && npm run deploy",
    "test:trading-gate": "node ../scripts/trading-gate-smoke-test.mjs",
    "test:l2:routing": "node ./scripts/l2-settlement-routing-smoke.mjs",
    "test:l2:routing:self": "node ./scripts/l2-settlement-routing-smoke.mjs --self-test",
    "test:grok": "node ./grok-test.mjs",
    "verify:dual-domain": "node ./scripts/verify-dual-domain-deployment.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.50",
    "@ai-sdk/xai": "^3.0.72",
    "@aws-sdk/client-s3": "^3.1005.0",
    "@huggingface/inference": "^2.7.0",
    "@supabase/supabase-js": "^2.49.8",
    "ai": "^6.0.134",
    "dotenv": "^17.3.1",
    "ethers": "^6.15.0",
    "lucide-react": "^0.546.0",
    "next": "^16.1.6",
    "pg": "^8.11.3",
    "plotly.js": "^3.4.0",
    "raw-body": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.30.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.18.0",
    "@vercel/node": "^5.6.15",
    "@vitejs/plugin-react": "^4.2.1",
    "terser": "^5.27.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": "24.x"
  }
}
