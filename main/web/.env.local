# TradeHax Environment Configuration
# Copy this file to .env.local and fill in your actual values

# --- CORE APP URLS (set per domain) ---
# For tradehaxai.tech:
NEXT_PUBLIC_APP_URL=https://tradehaxai.me
NEXT_PUBLIC_FRONTEND_URL=https://tradehaxai.me
NEXT_PUBLIC_SITE_URL=https://tradehaxai.me
# For tradehax.net, duplicate and change to https://tradehax.net
# For tradehaxai.me, duplicate and change to https://tradehaxai.me

# --- BACKEND API (set per domain) ---
# For tradehaxai.tech:
NEXT_PUBLIC_BACKEND_URL=https://api.tradehaxai.me
VITE_BACKEND_URL=https://api.tradehaxai.me
# For tradehax.net, duplicate and change to https://api.tradehax.net
# For tradehaxai.me, duplicate and change to https://api.tradehaxai.me

# --- AI/LLM ---
HUGGINGFACE_API_KEY=hf_your_token_here
OPENAI_API_KEY=sk_your_key_here
VITE_AI_CHAT_ENDPOINT=https://api.tradehaxai.me/ai/chat
VITE_AI_MODEL=tradehax-quant-v1

# --- SOLANA/BLOCKCHAIN ---
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_HELIUS_API_KEY=your-helius-key

# --- DATA PROVIDERS ---
VITE_POLYGON_API_KEY=your-polygon-key
VITE_FINNHUB_API_KEY=your-finnhub-key
VITE_ALPHA_VANTAGE_KEY=your-alpha-key

# --- SUPABASE (shared across all domains) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_jwt_here
SUPABASE_SECRET_KEY=sb_secret_your_secret_here

# --- STORAGE ---
VITE_MASSIVE_ACCESS_KEY=your_massive_access_key_here
VITE_MASSIVE_SECRET_KEY=your_massive_secret_key_here
VITE_MASSIVE_S3_ENDPOINT=https://files.massive.com
VITE_MASSIVE_BUCKET=flatfiles

# --- FEATURE FLAGS ---
VITE_ENABLE_PAPER_TRADING=true
VITE_ENABLE_LIVE_TRADING=true
VITE_ENABLE_FILE_STORAGE=true

# --- ANALYTICS (optional) ---
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=vercel-analytics-id

# --- CONTACT ---
NEXT_PUBLIC_CONTACT_EMAIL=support@tradehaxai.me

# --- LEGACY/COMPATIBILITY (optional) ---
VITE_HF_TOKEN=your_huggingface_token_here
REACT_APP_HF_TOKEN=your_huggingface_token_here
REACT_APP_POLYGON_API_KEY=your-polygon-key
REACT_APP_FINNHUB_API_KEY=your-finnhub-key
REACT_APP_ALPHA_VANTAGE_KEY=your-alpha-key
REACT_APP_MASSIVE_ACCESS_KEY=your_massive_access_key_here
REACT_APP_MASSIVE_SECRET_KEY=your_massive_secret_key_here
REACT_APP_MASSIVE_S3_ENDPOINT=https://files.massive.com
REACT_APP_MASSIVE_BUCKET=flatfiles

# --- APP CONFIG ---
VITE_APP_ENV=production
VITE_API_BASE_URL=https://api.tradehaxai.me

# --- END ---
