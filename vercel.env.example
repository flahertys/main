# TradeHax Snow Removal - Vercel Environment Template
# Copy these into Vercel Project Settings -> Environment Variables (Production/Preview/Development)
# Full guide: SNOW_REMOVAL_VERCEL_SETUP.md

# Frontend EmailJS (public)
# EmailJS Dashboard -> Email Services -> Service ID
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_gd7hfdd
# EmailJS Dashboard -> Email Templates -> Template ID
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=AOH1UXgT7P2icvBys
# EmailJS Dashboard -> Account -> API Keys -> Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=kgIcmFF2e3Calz-RSrOwH

# Backend notification delivery (private)
# Alternate route: SMTP (recommended if EmailJS is unreliable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_or_email
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM=snow@yourdomain.com
# Optional if SNOW_REMOVAL_TO_EMAIL is already set
SMTP_TO=njsnowremoval26@gmail.com

# Resend Dashboard -> API Keys
RESEND_API_KEY=your_resend_api_key
# Verified sender/domain in Resend
SNOW_REMOVAL_FROM_EMAIL=snow@yourdomain.com
# Destination inbox for leads
SNOW_REMOVAL_TO_EMAIL=njsnowremoval26@gmail.com

# Vercel deployment protection bypass (optional for automation)
VERCEL_AUTOMATION_BYPASS_SECRET=otWDNt0dMxhdDDdkNEPwodop676ofPP1
